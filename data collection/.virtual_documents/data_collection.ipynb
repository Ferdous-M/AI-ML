import requests


URL = "https://stephen-king-api.onrender.com/api/books"

res = requests.get(URL)
if res.status_code == 200 :
   #print(res.text)
   #print(res.content)
   print(res.headers)


json_data = res.json()
#print(json_data)


import pandas as pd

df = pd.json_normalize(json_data["data"])
df = df[['id', 'Title', 'Year', 'ISBN']]
df


