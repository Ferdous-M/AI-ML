df = pd.read_csv("globalAirQuality.csv")
print(type(df))

#print(df.head())
#print(df.tail())
print(df.describe())


# Selecting Data

# Select columns
df["country"]
df[["city", "aqi"]]

# Select rows (by label)
df.loc[0]             # 1st row (by label)
df.loc[0:3]           # row0 to row3 - both inclusive in loc

# Select rows (by index)
df.iloc[0]            # 1st row 
df.iloc[4:7]          # 1st row 

# Select rows & columns
df.loc[0, "country"]  # 0th row & specific column
df.iloc[0, 2]         # 1th row & 3rd column (by position)

#df.iloc[0:3, 2]
df.loc[0:2, ["country", "aqi"]]

# Select single scalar value
df.at[0, "city"]
df.iat[0, 2]


# Filtering Data
df[df["aqi"] > 100]
df[df["aqi"] > 100][["city", "aqi"]]


# Filtering Data
df[df["aqi"] > 100]



